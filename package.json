{
  "name": "boilerplate",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "server.js",
  "scripts": {
    "dist": "tsup src/server.ts --out-dir dist --format esm --target node20 --external onnxruntime-node --minify --clean",
    "start": "tsx --env-file=.env src/server.ts",
    "start:dist": "npm run dist && node --env-file=.env dist/server.js",
    "start:watch": "tsx watch --env-file=.env src/server.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongodb": "^7.1.0",
    "nodemailer": "^8.0.2",
    "playwright": "^1.58.2"
  }
}
